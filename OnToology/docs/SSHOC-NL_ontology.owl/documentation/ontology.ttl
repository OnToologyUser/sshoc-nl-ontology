@prefix : <https://kg.odissei.nl/SSHOC-NL-ontology.owl#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <https://kg.odissei.nl/SSHOC-NL-ontology.owl#> .

<https://kg.odissei.nl/SSHOC-NL-ontology.owl> rdf:type owl:Ontology ;
                                               <http://purl.org/dc/terms/creator> "Andre Valdestilhas" ;
                                               rdfs:comment "This is the ontology documentation for the SSHOC-NL Knowledge Graph, available at https://kg.odissei.nl/." ;
                                               rdfs:label "SSHOC-NL ontology" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/creator
<http://purl.org/dc/terms/creator> rdf:type owl:AnnotationProperty .


###  http://purl.org/ontology/bibo/annotates
<http://purl.org/ontology/bibo/annotates> rdf:type owl:AnnotationProperty ;
                                          rdfs:domain <http://purl.org/ontology/bibo/Note> .


###  http://purl.org/ontology/bibo/reviewOf
<http://purl.org/ontology/bibo/reviewOf> rdf:type owl:AnnotationProperty ;
                                         rdfs:domain <http://purl.org/ontology/bibo/Document> .


###  http://purl.org/ontology/bibo/transcriptOf
<http://purl.org/ontology/bibo/transcriptOf> rdf:type owl:AnnotationProperty ;
                                             rdfs:domain <http://purl.org/ontology/bibo/Document> .


###  http://www.w3.org/1999/02/22-rdf-syntax-ns#object
rdf:object rdf:type owl:AnnotationProperty ;
           rdfs:domain rdf:Statement .


###  http://www.w3.org/1999/02/22-rdf-syntax-ns#predicate
rdf:predicate rdf:type owl:AnnotationProperty ;
              rdfs:domain rdf:Statement .


###  http://www.w3.org/1999/02/22-rdf-syntax-ns#subject
rdf:subject rdf:type owl:AnnotationProperty ;
            rdfs:domain rdf:Statement .


###  http://www.w3.org/2000/01/rdf-schema#comment
rdfs:comment rdfs:range rdfs:Literal .


###  http://www.w3.org/2000/01/rdf-schema#label
rdfs:label rdfs:range rdfs:Literal .


###  http://www.w3.org/2004/02/skos/core#memberList
<http://www.w3.org/2004/02/skos/core#memberList> rdf:type owl:AnnotationProperty ;
                                                 rdfs:domain <http://www.w3.org/2004/02/skos/core#OrderedCollection> .


###  https://w3id.org/dsv-ontology#columnCompleteness
<https://w3id.org/dsv-ontology#columnCompleteness> rdf:type owl:AnnotationProperty ;
                                                   rdfs:domain <https://w3id.org/dsv-ontology#SummaryStatistics> .


###  https://w3id.org/dsv-ontology#datasetCompleteness
<https://w3id.org/dsv-ontology#datasetCompleteness> rdf:type owl:AnnotationProperty ;
                                                    rdfs:domain <https://w3id.org/dsv-ontology#SummaryStatistics> .


###  https://w3id.org/dsv-ontology#hasCategories
<https://w3id.org/dsv-ontology#hasCategories> rdf:type owl:AnnotationProperty ;
                                              rdfs:domain <https://w3id.org/dsv-ontology#CategoricalDataType> .


###  https://w3id.org/dsv-ontology#missingValueFormat
<https://w3id.org/dsv-ontology#missingValueFormat> rdf:type owl:AnnotationProperty ;
                                                   rdfs:domain <https://w3id.org/dsv-ontology#SummaryStatistics> .


###  https://w3id.org/dsv-ontology#numberOfColumns
<https://w3id.org/dsv-ontology#numberOfColumns> rdf:type owl:AnnotationProperty ;
                                                rdfs:domain <https://w3id.org/dsv-ontology#SummaryStatistics> .


###  https://w3id.org/dsv-ontology#numberOfRows
<https://w3id.org/dsv-ontology#numberOfRows> rdf:type owl:AnnotationProperty ;
                                             rdfs:domain <https://w3id.org/dsv-ontology#SummaryStatistics> .


